From 18ed888a50a489182ad299c5e445934fe5206dd3 Mon Sep 17 00:00:00 2001
From: scosman <scosman@gmail.com>
Date: Tue, 7 Jul 2026 18:18:57 +0000
Subject: [PATCH] fix(base): correct the built-in numFmtId table (ECMA-376)

DEFAULT_NUM_FMTS is indexed by numFmtId, but from id ~18 onward the entries were
misaligned and partly garbage: the id 37-40 paren formats sat at indices 23-26,
ids 45-49 sat at 28-32, and indices 38-44 held placeholder codes like "t0.00".
As a result get_num_fmt(id) returned the wrong code for most standard built-ins;
e.g. id 39 returned "t0.00", which the formatter cannot parse, so a valid number
in a cell using built-in format 39 rendered as #VALUE! instead of #,##0.00.

Rebuild the table as the canonical ECMA-376 (18.8.30) built-ins indexed by id,
restoring the reserved 23-36 gap (-> "general") and placing ids 37-49 correctly.
A workbook-defined numFmt still takes precedence (get_num_fmt checks it first).

Tests: assert the id->code mapping, precedence, the id 39 regression, and that
every corrected code actually formats a value without error. Note: id 47
("mmss.0") is the correct code but the formatter does not yet parse that
pattern - a separate formatter gap, documented and excluded from the render check.

Co-Authored-By: Claude Opus 4.8 <noreply@anthropic.com>
---
 base/src/number_format.rs | 171 ++++++++++++++++++++++++++++----------
 1 file changed, 126 insertions(+), 45 deletions(-)

diff --git a/base/src/number_format.rs b/base/src/number_format.rs
index f8ea443..e35462b 100644
--- a/base/src/number_format.rs
+++ b/base/src/number_format.rs
@@ -4,52 +4,62 @@ use crate::{
     types::NumFmt,
 };
 
+// The standard built-in number formats defined by ECMA-376 (§18.8.30), indexed by `numFmtId`
+// so that `DEFAULT_NUM_FMTS[id]` is the format code for that built-in id. Ids 23–36 are
+// reserved/undefined by the spec and resolve to "general". A workbook-defined `numFmt` always
+// takes precedence over this table (see `get_num_fmt`), so this is only consulted for a
+// referenced-but-undefined built-in id.
 const DEFAULT_NUM_FMTS: &[&str] = &[
-    "general",
-    "0",
-    "0.00",
-    "#,##0",
-    "#,##0.00",
-    "$#,##0; \\ - $#,##0",
-    "$#,##0; [Red] \\ - $#,##0",
-    "$#,##0.00; \\ - $#,##0.00",
-    "$#,##0.00; [Red] \\ - $#,##0.00",
-    "0%",
-    "0.00%",
-    "0.00E + 00",
-    "#?/?",
-    "#?? / ??",
-    "mm-dd-yy",
-    "d-mmm-yy",
-    "d-mmm",
-    "mmm-yy",
-    "h:mm AM / PM",
-    "h:mm:ss AM / PM",
-    "h:mm",
-    "h:mm:ss",
-    "m / d / yy h:mm",
-    "#,##0;()#,##0)",
-    "#,##0; [Red]()#,##0)",
-    "#,##0.00;()#,##0.00)",
-    "#,##0.00; [Red]()#,##0.00)",
-    "_()$”*#,##0.00 _); _()$”* \\()#,##0.00\\); _()$”* - ?? _); _()@_)",
-    "mm:ss",
-    "[h]:mm:ss",
-    "mmss .0",
-    "##0.0E + 0",
-    "@",
-    "[$ -404] e / m / d ",
-    "m / d / yy",
-    "[$ -404] e / m / d",
-    "[$ -404] e / / d",
-    "[$ -404] e / m / d",
-    "t0",
-    "t0.00",
-    "t#,##0",
-    "t#,##0.00",
-    "t0%",
-    "t0.00 %",
-    "t#?/?",
+    "general",                                                              // 0
+    "0",                                                                    // 1
+    "0.00",                                                                 // 2
+    "#,##0",                                                                // 3
+    "#,##0.00",                                                             // 4
+    "$#,##0_);($#,##0)",                                                    // 5
+    "$#,##0_);[Red]($#,##0)",                                               // 6
+    "$#,##0.00_);($#,##0.00)",                                              // 7
+    "$#,##0.00_);[Red]($#,##0.00)",                                         // 8
+    "0%",                                                                   // 9
+    "0.00%",                                                                // 10
+    "0.00E+00",                                                             // 11
+    "# ?/?",                                                                // 12
+    "# ??/??",                                                              // 13
+    "mm-dd-yy",                                                             // 14
+    "d-mmm-yy",                                                             // 15
+    "d-mmm",                                                                // 16
+    "mmm-yy",                                                               // 17
+    "h:mm AM/PM",                                                           // 18
+    "h:mm:ss AM/PM",                                                        // 19
+    "h:mm",                                                                 // 20
+    "h:mm:ss",                                                              // 21
+    "m/d/yy h:mm",                                                          // 22
+    "general",                                                              // 23 (reserved)
+    "general",                                                              // 24 (reserved)
+    "general",                                                              // 25 (reserved)
+    "general",                                                              // 26 (reserved)
+    "general",                                                              // 27 (reserved)
+    "general",                                                              // 28 (reserved)
+    "general",                                                              // 29 (reserved)
+    "general",                                                              // 30 (reserved)
+    "general",                                                              // 31 (reserved)
+    "general",                                                              // 32 (reserved)
+    "general",                                                              // 33 (reserved)
+    "general",                                                              // 34 (reserved)
+    "general",                                                              // 35 (reserved)
+    "general",                                                              // 36 (reserved)
+    "#,##0_);(#,##0)",                                                      // 37
+    "#,##0_);[Red](#,##0)",                                                 // 38
+    "#,##0.00_);(#,##0.00)",                                                // 39
+    "#,##0.00_);[Red](#,##0.00)",                                           // 40
+    "_(* #,##0_);_(* \\(#,##0\\);_(* \"-\"_);_(@_)",                        // 41
+    "_(\"$\"* #,##0_);_(\"$\"* \\(#,##0\\);_(\"$\"* \"-\"_);_(@_)",         // 42
+    "_(* #,##0.00_);_(* \\(#,##0.00\\);_(* \"-\"??_);_(@_)",                // 43
+    "_(\"$\"* #,##0.00_);_(\"$\"* \\(#,##0.00\\);_(\"$\"* \"-\"??_);_(@_)", // 44
+    "mm:ss",                                                                // 45
+    "[h]:mm:ss",                                                            // 46
+    "mmss.0",                                                               // 47
+    "##0.0E+0",                                                             // 48
